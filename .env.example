GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=your-password

# Alternative style used by garmin-grafana:
# GARMINCONNECT_EMAIL=you@example.com
# GARMINCONNECT_BASE64_PASSWORD=base64-encoded-password

# Defaults to ./.garmin-tokens
GARMIN_TOKEN_DIR=.garmin-tokens

# Set to true for Garmin China accounts.
GARMIN_IS_CN=false
