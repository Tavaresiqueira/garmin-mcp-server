# Recommended setup:
# Run `npm run login` and enter your Garmin credentials interactively.
# The server will use the token cache and does not need your password in this file.

# Optional non-interactive setup:
# GARMIN_EMAIL=you@example.com
# GARMIN_PASSWORD=your-password

# Defaults to ./.garmin-tokens
GARMIN_TOKEN_DIR=.garmin-tokens

# Set to true for Garmin China accounts.
GARMIN_IS_CN=false
